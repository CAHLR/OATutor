    {
        "id": "a9cf10atrig30a-h1",
        "type": "hint",
        "dependencies": [],
        "title": "Identity",
        "text": "$$\\sec(\\theta)=\\frac{1}{\\cos(\\theta)},\\ \\tan(\\theta)=\\frac{\\sin(\\theta)}{\\cos(\\theta)},\\ \\cot(\\theta)=\\frac{\\cos(\\theta)}{\\sin(\\theta)}$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig30a-h2",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig30a-h1"
        ],
        "title": "Substitute",
        "text": "Substitute identities into $$\\frac{\\sec(\\theta)+\\tan(\\theta)}{\\cot(\\theta)+\\cos(\\theta)}.$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig30a-h3",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig30a-h2"
        ],
        "title": "Factor",
        "text": "$$\\frac{\\frac{1}{\\cos(\\theta)}+\\frac{\\sin(\\theta)}{\\cos(\\theta)}}{\\frac{\\cos(\\theta)}{\\sin(\\theta)}+\\cos(\\theta)}$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig30a-h4",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig30a-h3"
        ],
        "title": "Simplify",
        "text": "$$\\frac{\\sin(\\theta)+1}{\\frac{1}{\\sin(\\theta)}+1}=\\sin(\\theta)$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig30a-h5",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig30a-h4"
        ],
        "title": "Simplify Further",
        "text": "$$\\frac{\\sin(\\theta)}{\\cos**2(\\theta)}=\\frac{\\sin(\\theta)}{\\cos(\\theta)}\\cdot\\frac{1}{\\cos(\\theta)}=\\tan(\\theta)\\sec(\\theta)$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig30a-h6",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig30a-h5"
        ],
        "title": "Evaluate",
        "text": "So $$\\frac{\\sec(\\theta)+\\tan(\\theta)}{\\cot(\\theta)+\\cos(\\theta)}=\\tan(\\theta)\\sec(\\theta),$$ not $$\\sec**2(\\theta).$$ Therefore the statement is false.",
        "variabilization": {},
        "oer": "",
        "license": ""
    }
