        "dependencies": [
            "a642536polar28a-h2"
        ],
        "title": "Trigonometric Identity",
        "text": "$$2sin(\\theta)cos(\\theta)=2sin2(\\theta)$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
