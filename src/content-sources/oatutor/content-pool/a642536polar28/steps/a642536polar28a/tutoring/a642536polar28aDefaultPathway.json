        ],
        "title": "Substitute",
        "text": "$$4\\operatorname{rcos}\\left(\\theta\\right) \\operatorname{rsin}\\left(\\theta\\right)+2r^2=r^{2\\left(4cos\\left(\\theta\\right) sin\\left(\\theta\\right)+2\\right)}=9$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
