        ],
        "title": "Rationalize",
        "text": "Multiply the numerator and denominator of $$\\frac{\\cos(\\theta)}{1+\\sin(\\theta)}$$ by $$\\frac{\\cos(\\theta)}{\\cos(\\theta)}.$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig14a-h3",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig14a-h2"
        ],
        "title": "Substitute",
        "text": "Substitute the identity $$\\cos**2(\\theta)=1-\\sin**2(\\theta).$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig14a-h4",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig14a-h3"
        ],
        "title": "Factor",
        "text": "$$1-sin^2\\left(\\theta\\right)=\\left(1-sin\\left(\\theta\\right)\\right) \\left(1+sin\\left(\\theta\\right)\\right)$$",
        "variabilization": {},
        "oer": "",
        "license": ""
    },
    {
        "id": "a9cf10atrig14a-h5",
        "type": "hint",
        "dependencies": [
            "a9cf10atrig14a-h4"
        ],
        "title": "Simplify",
        "text": "$$\\frac{(1-\\sin(\\theta))(1+\\sin(\\theta))}{\\cos(\\theta)(1+\\sin(\\theta))}=\\frac{1-\\sin(\\theta)}{\\cos(\\theta)}$$",
